# --- Database ---
MYSQL_ROOT_PASSWORD=change-me-root-secret
WORDPRESS_DB_NAME=lcgf_wp
WORDPRESS_DB_USER=lcgf_user
WORDPRESS_DB_PASSWORD=change-me-user-secret

# --- WordPress URL ---
# In Coolify viene sovrascritto dal dominio configurato
WP_HOME=http://localhost:8080
WP_SITEURL=http://localhost:8080
WP_FORCE_SSL=false
WP_DEBUG=0

# --- Porte (solo dev locale) ---
WP_PORT=8080
PMA_PORT=8081
